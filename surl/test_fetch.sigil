import std.io
import std.http
import std.list
import fetch
use std.io.{IO};
use std.http.{Request, Response, Header, Url};
use std.list.{List, Nil};
use fetch.{fetch};

fn main() -> Int ![IO, Net] {
  let url: Url = Url { scheme: "http", host: "127.0.0.1", port: 1, path: "/test", query: "" };
  let headers: List[Header] = Nil;
  let req: Request = std.http.get(url, headers);

  match perform fetch(req) {
    Ok(_) => {
      perform IO.println("ERROR: expected connection refused, got Ok");
      1
    },
    Err(msg) => {
      perform IO.println("fetch correctly returned Err");
      perform IO.println(msg);
      0
    },
  }
}
