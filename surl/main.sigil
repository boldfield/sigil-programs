import std.env
import std.io
import std.byte_array
import std.list
import std.mem
import std.net
import std.http
import std.int
import std.string
import args
import request
import fetch

use std.env.{env_args, Env};
use std.io.{IO};
use std.byte_array.{string_from_bytes};
use std.list.{List, Cons, Nil};
use std.mem.{Mem};
use std.net.{Net};
use std.http.{Header};
use std.int.{int_to_string};
use std.string.{string_concat};
use args.{parse_args};
use request.{build_request};
use fetch.{fetch};

fn print_headers(headers: List[Header]) -> Unit ![IO] {
  match headers {
    Nil => (),
    Cons(header, rest) => {
      perform IO.println(string_concat(header.name, string_concat(": ", header.value)));
      print_headers(rest)
    },
  }
}

fn main() -> Int ![IO, Env, Net, Mem] {
  let argv: List[String] = env_args();
  match parse_args(argv) {
    Err(usage_msg) => {
      perform IO.println(usage_msg);
      0
    },
    Ok(config) => {
      match build_request(config) {
        Err(err_msg) => {
          perform IO.println(err_msg);
          1
        },
        Ok(req) => {
          match fetch(req) {
            Err(err_msg) => {
              perform IO.println(err_msg);
              1
            },
            Ok(resp) => {
              match config.head_only {
                true => {
                  let status_line: String = string_concat("HTTP/1.1 ", string_concat(int_to_string(resp.status), string_concat(" ", resp.reason)));
                  perform IO.println(status_line);
                  perform print_headers(resp.headers);
                  0
                },
                false => {
                  match string_from_bytes(resp.body) {
                    None => {
                      perform IO.println("Error: invalid UTF-8 in response body");
                      1
                    },
                    Some(body_str) => {
                      perform IO.println(body_str);
                      0
                    },
                  }
                },
              }
            },
          }
        },
      }
    },
  }
}
