import std.io
import std.list
import std.string
import std.option
import std.http
import std.ordering
import args
import request

use std.io.{IO};
use std.list.{Cons, List, Nil};
use std.string.{string_concat, string_compare};
use std.option.{None, Option, Some};
use std.ordering.{Equal};
use std.http.{Header, Request};
use args.{Config};
use request.{build_request};

fn find_host_header(headers: List[Header]) -> Option[String] ![] {
  match headers {
    Nil => None,
    Cons(h, rest) => {
      match string_compare(h.name, "Host") {
        Equal => Some(h.value),
        _ => find_host_header(rest),
      }
    },
  }
}

fn verify_request(req: Request) -> Int ![IO] {
  let method_ok: Bool = match string_compare(req.method, "GET") {
    Equal => true,
    _ => false,
  };
  let host: String = req.url.host;
  let host_header_ok: Bool = match find_host_header(req.headers) {
    Some(h) => match string_compare(h, "example.com") {
      Equal => true,
      _ => false,
    },
    None => false,
  };
  match method_ok {
    true => {
      match host_header_ok {
        true => {
          perform IO.println("✓ method is GET");
          perform IO.println("✓ Host header correct");
          perform IO.println(string_concat("✓ url.host: ", host));
          0
        },
        false => {
          perform IO.println("✗ Host header incorrect");
          1
        },
      }
    },
    false => {
      perform IO.println("✗ method is not GET");
      1
    },
  }
}

fn main() -> Int ![IO] {
  let config: Config = Config {
    url: "http://example.com/path",
    method: "GET",
    headers: Nil,
    data: "",
    output: "",
    head_only: false,
    follow: false,
    user: "",
    cookie: "",
    cookie_jar: "",
    verbose: false,
    insecure: false,
  };

  match build_request(config) {
    Ok(req) => verify_request(req),
    Err(msg) => {
      perform IO.println(string_concat("Error building request: ", msg));
      1
    },
  }
}
