import lexer
import ast
import std.io
import std.string
import std.list
use std.io.{IO};
use std.string.{String};
use std.list.{List};
use lexer.{lex, LexResult};
use ast.{Token, Dot, Identifier};

fn token_to_string(tok: Token) -> String {
  match tok {
    case Dot => "Dot"
    case Identifier(s) => String.append("Identifier(", String.append(s, ")"))
  }
}

fn tokens_to_string(tokens: List[Token]) -> String {
  match tokens {
    case [] => "[]"
    case tokens => {
      let strs = List.map(tokens, fn(t: Token) -> String { token_to_string(t) });
      let joined = String.join(", ", strs);
      String.append("[", String.append(joined, "]"))
    }
  }
}

fn main() -> Int ![IO] {
  // Test 1: lex "."
  let result1 = lex(".");
  match result1 {
    case Ok(tokens) => {
      perform IO.println(String.append("lex('.'): ", tokens_to_string(tokens)));
    }
    case Error(msg) => {
      perform IO.println(String.append("lex('.'): Error - ", msg));
    }
  };

  // Test 2: lex ".foo"
  let result2 = lex(".foo");
  match result2 {
    case Ok(tokens) => {
      perform IO.println(String.append("lex('.foo'): ", tokens_to_string(tokens)));
    }
    case Error(msg) => {
      perform IO.println(String.append("lex('.foo'): Error - ", msg));
    }
  };

  // Test 3: lex "foo"
  let result3 = lex("foo");
  match result3 {
    case Ok(tokens) => {
      perform IO.println(String.append("lex('foo'): ", tokens_to_string(tokens)));
    }
    case Error(msg) => {
      perform IO.println(String.append("lex('foo'): Error - ", msg));
    }
  };

  perform IO.println("lexer: core tokens (dot, identifiers) constructed successfully");
  0
}
