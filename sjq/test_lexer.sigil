import lexer
import ast
import std.io
import std.string
import std.list
use std.io.{IO}
use std.list.{map, Cons, Nil}
use std.string.{string_concat, string_join}
use lexer.{lex, LexResult}
use ast.{Token, Dot, Identifier}

fn token_to_string(tok: Token) -> String =>
  match tok {
    Dot => "Dot"
    Identifier(s) => string_concat(string_concat("Identifier(", s), ")")
  }

fn tokens_to_string(tokens: List[Token]) -> String =>
  match tokens {
    Nil => "[]"
    _ => {
      let strs = map(tokens, fn (t: Token) -> String => token_to_string(t))
      let joined = string_join(", ", strs)
      string_concat(string_concat("[", joined), "]")
    }
  }

fn main() -> Int ![IO] {
  // Test 1: lex "."
  let result1 = lex(".");
  match result1 {
    Ok(tokens) => {
      perform IO.println(string_concat("lex('.'): ", tokens_to_string(tokens)));
    }
    Error(msg) => {
      perform IO.println(string_concat("lex('.'): Error - ", msg));
    }
  };

  // Test 2: lex ".foo"
  let result2 = lex(".foo");
  match result2 {
    Ok(tokens) => {
      perform IO.println(string_concat("lex('.foo'): ", tokens_to_string(tokens)));
    }
    Error(msg) => {
      perform IO.println(string_concat("lex('.foo'): Error - ", msg));
    }
  };

  // Test 3: lex "foo"
  let result3 = lex("foo");
  match result3 {
    Ok(tokens) => {
      perform IO.println(string_concat("lex('foo'): ", tokens_to_string(tokens)));
    }
    Error(msg) => {
      perform IO.println(string_concat("lex('foo'): Error - ", msg));
    }
  };

  perform IO.println("lexer: core tokens (dot, identifiers) constructed successfully");
  0
}
