import ast
import std.json
import std.list
import std.option
import std.ordering
use ast.{Filter};
use std.json.{JValue, JObject, JONil, JOCons};
use std.list.{List, Nil, Cons};
use std.option.{Option, None, Some};
use std.ordering.{Ordering, Equal, string_compare};

fn lookup_field(key: String, obj: JObject) -> Option[JValue] ![] {
  match obj {
    JONil => None,
    JOCons(k, v, rest) => {
      match string_compare(k, key) {
        Equal => Some(v),
        _ => lookup_field(key, rest),
      }
    },
  }
}

fn eval(filter: Filter, input: JValue) -> List[JValue] ![] {
  match filter {
    Identity => Cons(input, Nil),
    Field(key) => {
      match input {
        JObject(obj) => {
          match lookup_field(key, obj) {
            Some(v) => Cons(v, Nil),
            None => Nil,
          }
        },
        _ => Nil,
      }
    },
    Index(_) => Nil,
    Iterate => Nil,
    Pipe(_, _) => Nil,
    Length => Nil,
    Keys => Nil,
    Select(_) => Nil,
  }
}
