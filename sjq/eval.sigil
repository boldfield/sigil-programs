import ast
import std.json
import std.list
import std.option
import std.ordering
import std.string
use ast.{Filter};
use std.json.{JValue, JNull, JArray, JList, JLNil, JLCons, JObject, JONil, JOCons, JInt, JString, JBool};
use std.list.{List, Nil, Cons, append, length as list_length, range, list_sort_string};
use std.option.{Option, None, Some};
use std.ordering.{Ordering, Equal, string_compare};
use std.string.{string_length};

fn lookup_field(key: String, obj: JObject) -> Option[JValue] ![] {
  match obj {
    JONil => None,
    JOCons(k, v, rest) => {
      match string_compare(k, key) {
        Equal => Some(v),
        _ => lookup_field(key, rest),
      }
    },
  }
}

fn jlist_get(jlist: JList, index: Int) -> Option[JValue] ![] {
  match index < 0 {
    true => None,
    false => {
      match index {
        0 => {
          match jlist {
            JLNil => None,
            JLCons(v, _) => Some(v),
          }
        },
        _ => {
          match jlist {
            JLNil => None,
            JLCons(_, rest) => jlist_get(rest, index - 1),
          }
        },
      }
    },
  }
}

fn jlist_to_list(jlist: JList) -> List[JValue] ![] {
  match jlist {
    JLNil => Nil,
    JLCons(v, rest) => Cons(v, jlist_to_list(rest)),
  }
}

fn jobject_values(obj: JObject) -> List[JValue] ![] {
  match obj {
    JONil => Nil,
    JOCons(_, v, rest) => Cons(v, jobject_values(rest)),
  }
}

fn jlist_length(jlist: JList) -> Int ![] {
  match jlist {
    JLNil => 0,
    JLCons(_, rest) => 1 + jlist_length(rest),
  }
}

fn jobject_length(obj: JObject) -> Int ![] {
  match obj {
    JONil => 0,
    JOCons(_, _, rest) => 1 + jobject_length(rest),
  }
}

fn jobject_keys(obj: JObject) -> List[String] ![] {
  match obj {
    JONil => Nil,
    JOCons(k, _, rest) => Cons(k, jobject_keys(rest)),
  }
}

fn string_list_to_jlist(strs: List[String]) -> JList ![] {
  match strs {
    Nil => JLNil,
    Cons(s, rest) => JLCons(JString(s), string_list_to_jlist(rest)),
  }
}

fn int_list_to_jlist(ints: List[Int]) -> JList ![] {
  match ints {
    Nil => JLNil,
    Cons(n, rest) => JLCons(JInt(n), int_list_to_jlist(rest)),
  }
}

fn eval_pipe_helper(filter_b: Filter, values: List[JValue]) -> List[JValue] ![] {
  match values {
    Nil => Nil,
    Cons(v, rest) => {
      let results_for_v: List[JValue] = eval(filter_b, v);
      let rest_results: List[JValue] = eval_pipe_helper(filter_b, rest);
      append(results_for_v, rest_results)
    },
  }
}

fn is_truthy(value: JValue) -> Bool ![] {
  match value {
    JBool(b) => b,
    JNull => false,
    _ => true,
  }
}

fn any_truthy(values: List[JValue]) -> Bool ![] {
  match values {
    Nil => false,
    Cons(v, rest) => {
      match is_truthy(v) {
        true => true,
        false => any_truthy(rest),
      }
    },
  }
}

fn eval(filter: Filter, input: JValue) -> List[JValue] ![] {
  match filter {
    Identity => Cons(input, Nil),
    Field(key) => {
      match input {
        JObject(obj) => {
          match lookup_field(key, obj) {
            Some(v) => Cons(v, Nil),
            None => Cons(JNull, Nil),
          }
        },
        JNull => Cons(JNull, Nil),
        _ => panic("cannot index non-object with string key"),
      }
    },
    Index(n) => {
      match input {
        JArray(jlist) => {
          match jlist_get(jlist, n) {
            Some(v) => Cons(v, Nil),
            None => Cons(JNull, Nil),
          }
        },
        JNull => Cons(JNull, Nil),
        _ => panic("cannot index non-array with numeric index"),
      }
    },
    Iterate => {
      match input {
        JArray(jlist) => jlist_to_list(jlist),
        JObject(obj) => jobject_values(obj),
        _ => panic("cannot iterate over non-array/object"),
      }
    },
    Pipe(a, b) => {
      let first_results: List[JValue] = eval(a, input);
      eval_pipe_helper(b, first_results)
    },
    Length => {
      match input {
        JArray(jlist) => Cons(JInt(jlist_length(jlist)), Nil),
        JObject(obj) => Cons(JInt(jobject_length(obj)), Nil),
        JString(s) => Cons(JInt(string_length(s)), Nil),
        JNull => Cons(JInt(0), Nil),
        _ => panic("cannot get length of non-array/object/string"),
      }
    },
    Keys => {
      match input {
        JObject(obj) => {
          let keys: List[String] = jobject_keys(obj);
          let sorted_keys: List[String] = list_sort_string(keys);
          let jlist: JList = string_list_to_jlist(sorted_keys);
          Cons(JArray(jlist), Nil)
        },
        JArray(jlist) => {
          let len: Int = jlist_length(jlist);
          let indices: List[Int] = range(0, len);
          let jlist_indices: JList = int_list_to_jlist(indices);
          Cons(JArray(jlist_indices), Nil)
        },
        _ => panic("cannot get keys of non-object/array"),
      }
    },
    Select(inner) => {
      let results: List[JValue] = eval(inner, input);
      match any_truthy(results) {
        true => Cons(input, Nil),
        false => Nil,
      }
    },
  }
}
