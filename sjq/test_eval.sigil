  let t16: Int = test_select_truthy_field();
  let t17: Int = test_select_false_field();
  let t18: Int = test_select_null_field();
  let t19: Int = test_select_true_field();
  match t1 {
    0 => match t2 {
      0 => match t3 {
        0 => match t4 {
          0 => match t5 {
            0 => match t6 {
              0 => match t7 {
                0 => match t8 {
                  0 => match t9 {
                    0 => match t10 {
                      0 => match t11 {
                        0 => match t12 {
                          0 => match t13 {
                            0 => match t14 {
                              0 => match t15 {
                                0 => match t16 {
                                  0 => match t17 {
                                    0 => match t18 {
                                      0 => t19,
                                      _ => t18,
                                    },
                                    _ => t17,
                                  },
                                  _ => t16,
                                },
                                _ => t15,
                              },
                              _ => t14,
                            },
                            _ => t13,
                          },
                          _ => t12,
                        },
                        _ => t11,
                      },
                      _ => t10,
                    },
                    _ => t9,
                  },
                  _ => t8,
                },
                _ => t7,
              },
              _ => t6,
            },
            _ => t5,
          },
          _ => t4,
        },
        _ => t3,
      },
      _ => t2,
    },
    _ => t1,
  }
}
