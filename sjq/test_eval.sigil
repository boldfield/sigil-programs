fn test_pipe_iterate_field() -> Int ![IO, Mem] {
  let obj1: JObject = JOCons("foo", JString("alice"), JONil);
  let obj2: JObject = JOCons("foo", JString("bob"), JONil);
  let jlist: JList = JLCons(JObject(obj1), JLCons(JObject(obj2), JLNil));
  let input: JValue = JArray(jlist);
  let filter: Filter = Pipe(Iterate, Field("foo"));
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JString("alice"), Cons(JString("bob"), Nil));
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_pipe_iterate_field: PASS");
      0
    },
    false => {
      perform IO.println("test_pipe_iterate_field: FAIL");
      1
    },
  }
}

