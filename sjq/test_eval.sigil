import ast
import eval
import std.io
import std.json
import std.list
import std.mem
import std.ordering
import std.string
use ast.{Filter, Identity, Field, Index, Iterate};
use eval.{eval};
use std.io.{IO};
use std.json.{JValue, JArray, JList, JLNil, JLCons, JObject, JOCons, JONil, JInt, JString, JNull, json_render};
use std.list.{List, Nil, Cons};
use std.mem.{Mem};
use std.ordering.{Equal, string_compare};
use std.string.{string_concat};

fn int_equal(a: Int, b: Int) -> Bool ![] {
  match a - b {
    0 => true,
    _ => false,
  }
}

fn jvalues_equal(x: JValue, y: JValue) -> Bool ![] {
  match x {
    JNull => {
      match y {
        JNull => true,
        _ => false,
      }
    },
    JInt(a) => {
      match y {
        JInt(b) => int_equal(a, b),
        _ => false,
      }
    },
    JString(a) => {
      match y {
        JString(b) => {
          match string_compare(a, b) {
            Equal => true,
            _ => false,
          }
        },
        _ => false,
      }
    },
    _ => false,
  }
}

fn list_equals(xs: List[JValue], ys: List[JValue]) -> Bool ![] {
  match xs {
    Nil => {
      match ys {
        Nil => true,
        _ => false,
      }
    },
    Cons(x, xs_rest) => {
      match ys {
        Nil => false,
        Cons(y, ys_rest) => {
          match jvalues_equal(x, y) {
            true => list_equals(xs_rest, ys_rest),
            false => false,
          }
        },
      }
    },
  }
}

fn test_identity() -> Int ![IO, Mem] {
  let input: JValue = JInt(42);
  let filter: Filter = Identity;
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JInt(42), Nil);
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_identity: PASS");
      0
    },
    false => {
      perform IO.println("test_identity: FAIL");
      1
    },
  }
}

fn test_field() -> Int ![IO, Mem] {
  let obj: JObject = JOCons("name", JString("alice"), JOCons("age", JInt(30), JONil));
  let input: JValue = JObject(obj);
  let filter: Filter = Field("name");
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JString("alice"), Nil);
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_field: PASS");
      0
    },
    false => {
      perform IO.println("test_field: FAIL");
      1
    },
  }
}

fn test_field_missing() -> Int ![IO, Mem] {
  let obj: JObject = JOCons("name", JString("alice"), JONil);
  let input: JValue = JObject(obj);
  let filter: Filter = Field("missing");
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JNull, Nil);
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_field_missing: PASS");
      0
    },
    false => {
      perform IO.println("test_field_missing: FAIL");
      1
    },
  }
}

fn test_index() -> Int ![IO, Mem] {
  let jlist: JList = JLCons(JInt(10), JLCons(JInt(20), JLCons(JInt(30), JLNil)));
  let input: JValue = JArray(jlist);
  let filter: Filter = Index(1);
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JInt(20), Nil);
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_index: PASS");
      0
    },
    false => {
      perform IO.println("test_index: FAIL");
      1
    },
  }
}

fn test_index_out_of_range() -> Int ![IO, Mem] {
  let jlist: JList = JLCons(JInt(10), JLCons(JInt(20), JLNil));
  let input: JValue = JArray(jlist);
  let filter: Filter = Index(5);
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JNull, Nil);
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_index_out_of_range: PASS");
      0
    },
    false => {
      perform IO.println("test_index_out_of_range: FAIL");
      1
    },
  }
}

fn test_iterate_array() -> Int ![IO, Mem] {
  let jlist: JList = JLCons(JInt(1), JLCons(JInt(2), JLCons(JInt(3), JLNil)));
  let input: JValue = JArray(jlist);
  let filter: Filter = Iterate;
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JInt(1), Cons(JInt(2), Cons(JInt(3), Nil)));
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_iterate_array: PASS");
      0
    },
    false => {
      perform IO.println("test_iterate_array: FAIL");
      1
    },
  }
}

fn test_iterate_object() -> Int ![IO, Mem] {
  let obj: JObject = JOCons("a", JInt(1), JOCons("b", JInt(2), JONil));
  let input: JValue = JObject(obj);
  let filter: Filter = Iterate;
  let results: List[JValue] = eval(filter, input);
  let expected: List[JValue] = Cons(JInt(1), Cons(JInt(2), Nil));
  match list_equals(results, expected) {
    true => {
      perform IO.println("test_iterate_object: PASS");
      0
    },
    false => {
      perform IO.println("test_iterate_object: FAIL");
      1
    },
  }
}

fn main() -> Int ![IO, Mem] {
  let t1: Int = test_identity();
  let t2: Int = test_field();
  let t3: Int = test_field_missing();
  let t4: Int = test_index();
  let t5: Int = test_index_out_of_range();
  let t6: Int = test_iterate_array();
  let t7: Int = test_iterate_object();
  match t1 {
    0 => match t2 {
      0 => match t3 {
        0 => match t4 {
          0 => match t5 {
            0 => match t6 {
              0 => t7,
              _ => t6,
            },
            _ => t5,
          },
          _ => t4,
        },
        _ => t3,
      },
      _ => t2,
    },
    _ => t1,
  }
}
